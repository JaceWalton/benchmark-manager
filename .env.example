# Copy to  ~/benchmarks/.env  and fill in what you need. bmm auto-loads it.
# Only required for specific Tier-3 benchmarks; the built-ins need nothing here.

# --- endpoint overrides (defaults shown) ---
# BMM_ENDPOINT=http://127.0.0.1:9292/v1
# BMM_API_KEY=sk-local
# BMM_DEFAULT_LIMIT=20
# BMM_TIMEOUT=1800

# --- web search (GAIA / any search-agent benchmark) — pick one ---
# TAVILY_API_KEY=
# SERPER_API_KEY=
# BING_API_KEY=

# --- Hugging Face (gated datasets: GAIA, some SWE-bench splits) ---
# HF_TOKEN=

# --- GitHub (SWE-bench image pulls / rate limits) ---
# GITHUB_TOKEN=
